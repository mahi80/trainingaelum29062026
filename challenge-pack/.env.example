# AutoLoan-DocIntel — environment template.
# Copy to `.env` (which is git-ignored). Defaults are safe for LOCAL dev only.
# NEVER commit a real .env or real secrets. CI runs without any of these.

# ----- Postgres (loan warehouse + pgvector + app.session) --------------------
POSTGRES_USER=aldi
POSTGRES_PASSWORD=aldi
POSTGRES_DB=autoloan
POSTGRES_PORT=5432
# Used by the app container (host=postgres on the compose network):
DATABASE_URL=postgresql://aldi:aldi@postgres:5432/autoloan

# ----- Redis (cache / rate-limit / idempotency / sessions / streams) ---------
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# ----- Ollama (local LLM + embeddings) ---------------------------------------
OLLAMA_PORT=11434
OLLAMA_HOST=http://ollama:11434
LLM_PROVIDER=ollama
# Chat / reasoning model:
LLM_MODEL=llama3.1:8b
# NL->SQL generation model:
SQL_MODEL=qwen2.5-coder:7b
# Embedding model (MUST be 768-d to match the pgvector columns):
EMBED_MODEL=nomic-embed-text

# ----- App (FastAPI) ---------------------------------------------------------
APP_PORT=8000
# Secret for signing/argon2 pepper & OAuth2 tokens. CHANGE for any real use.
SECRET_KEY=dev-only-change-me
ACCESS_TOKEN_EXPIRE_MINUTES=60
# Structured logging:
LOG_LEVEL=INFO
LOG_FORMAT=json

# ----- MinIO (optional object store, profile: storage) -----------------------
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=minio123
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# ----- OpenMetadata (optional catalog, profile: catalog) ---------------------
# Only needed when running openmetadata.compose.yml. Heavy; off by default.
OM_PORT=8585
OM_ADMIN_PORT=8586
OM_MYSQL_PASSWORD=password
